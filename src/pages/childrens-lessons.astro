---
import BaseLayout from "../layouts/BaseLayout.astro";
import childrenBackground from "../assets/04.webp";
import rachelTeaching from "../assets/Extra-Rachel.jpg";

const withBase = (path: string) => `${import.meta.env.BASE_URL}${path.replace(/^\//, "")}`;
---

<BaseLayout
  title="Belgravia Ballet School | Children's Ballet Lessons"
  description="Children's ballet lessons from Belgravia Ballet School. A premium, warm, and inclusive environment with strong technique, RAD-approved training, and musical theatre experiences."
  backgroundImage={childrenBackground.src}
  backgroundPosition="center 24%"
>
  <section class="hero">
    <div class="hero-grid">
      <div>
        <span class="eyebrow">Children's Ballet</span>
        <h1>
          Premier ballet training for children,
          <span class="accent-script">rooted in technique, confidence, and joy.</span>
        </h1>
        <p class="hero-copy">
          Belgravia Ballet School is designed for families seeking established credentials, premium presentation, and a
          deeply supportive environment. Children's lessons nurture classical technique, personal development, and
          wellbeing while preserving the delight and aspiration that make dance memorable.
        </p>
        <div class="hero-actions">
          <a class="button primary" href={withBase("/book/?lesson=childrens-ballet")}>Enquire about children's classes</a>
          <a class="button secondary" href="#programme">View the programme</a>
        </div>
      </div>

      <div class="image-frame hero-portrait">
        <img src={rachelTeaching.src} alt="Hannah Lancaster teaching a young ballet student." />
      </div>
    </div>
  </section>

  <section id="programme" class="stack">
    <div class="feature-grid">
      <article class="card">
        <h3>Foundational ballet</h3>
        <p class="muted">
          Age-appropriate teaching that builds turnout awareness, coordination, musicality, and posture with calm,
          encouraging structure from the very beginning.
        </p>
      </article>

      <article class="card">
        <h3>RAD-approved rigour</h3>
        <p class="muted">
          The school’s training is positioned to appeal to parents looking for established standards, clear progression,
          and beautifully taught classical discipline.
        </p>
      </article>

      <article class="card">
        <h3>Musical theatre experiences</h3>
        <p class="muted">
          Alongside ballet technique, the school can support specialist musical theatre experiences that build stage
          confidence, expression, and performance quality.
        </p>
      </article>
    </div>

    <div class="split-grid">
      <article class="panel">
        <h2>The best possible start</h2>
        <div class="">
          <div class="detail">
            <span>Audience</span>
            Parents seeking premier ballet training for children
          </div>
          <div class="detail">
            <span>Core balance</span>
            Technique and theatrical expression working together
          </div>
          <div class="detail">
            <span>Environment</span>
            Inclusive, cohesive, and confidence-building
          </div>
        </div>
      </article>

      <article class="panel">
        <h2>A school built for progression and delight.</h2>
        <ul class="list">
          <li>Classes that combine structure with an inviting, nurturing atmosphere</li>
          <li>Training that supports both recreational students and ambitious young dancers</li>
          <li>Professional teaching from experienced co-founders and performers</li>
          <li>Strong visual emphasis on classical ballet heritage without feeling antiquated</li>
        </ul>
        <div class="button-row">
          <a class="button primary" href={withBase("/book/?lesson=childrens-ballet")}>Arrange a consultation</a>
          <a class="button secondary" href={withBase("/adult-ballet/")}>Explore adult ballet</a>
        </div>
      </article>
    </div>

    <div class="split-grid">
      <article class="teacher-card">
        <img src={rachelTeaching.src} alt="Hannah Lancaster supporting a child during ballet class." />
        <div class="teacher-body">
          <span class="teacher-title">Children's Training</span>
          <h3>Warm, precise teaching</h3>
          <p class="muted">
            Hannah Lancaster’s reassuring coaching style supports the brief’s focus on wellbeing, confidence, and a
            supportive environment alongside elite standards.
          </p>
        </div>
      </article>

      <article class="panel">
        <h2>Trusted guidance for ambitious families.</h2>
        <p class="muted">
          Families arriving here should understand immediately that the school blends established credentials with a
          supportive culture.
        </p>
        <ul class="list">
          <li>Founder-led teaching rooted in professional dance experience</li>
          <li>Presentation that feels elegant, modern, and classically informed</li>
          <li>Clear emphasis on confidence, development, and student wellbeing</li>
          <li>Suitable for both recreational dancers and more ambitious pathways</li>
        </ul>
      </article>
    </div>

    <div class="quote-panel">
      <p>"A cohesive and inclusive environment where the love of dance, wellbeing, and confidence thrive."</p>
    </div>
  </section>
</BaseLayout>
