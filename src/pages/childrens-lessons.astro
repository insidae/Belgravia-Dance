---
import BaseLayout from "../layouts/BaseLayout.astro";
import childrenBackground from "../assets/04.webp";

const withBase = (path: string) => `${import.meta.env.BASE_URL}${path.replace(/^\//, "")}`;
---

<BaseLayout
  title="Belgravia Dance | Children's Dance Lessons with Hannah Lancaster"
  description="Children's dance lessons in London with professional dancer Hannah Lancaster. Nurturing, structured training for young dancers and aspiring performers."
  backgroundImage={childrenBackground.src}
  backgroundPosition="center 25%"
>
  <section class="hero">
    <div class="hero-grid">
      <div>
        <span class="eyebrow">Children's Dance Lessons</span>
        <h1>Nurturing, professional tuition for young dancers.</h1>
        <p class="hero-copy">
          Hannah Lancaster offers structured dance lessons for children in a setting that feels both encouraging and
          aspirational. Sessions help young dancers build technique, musical awareness and performance confidence at the
          right pace for their age and experience.
        </p>
        <div class="hero-actions">
          <a class="button primary" href={withBase("/book/?lesson=children")}>Book a children's lesson</a>
          <a class="button secondary" href="#programme">View the programme</a>
        </div>
      </div>

      <div class="portrait">
        <div class="portrait-panel">
          <strong>Professional and reassuring</strong>
          <p class="muted">
            Hannah combines a high standard of training with a patient approach that helps children enjoy learning and feel proud of their progress.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section id="programme" class="stack">
    <div class="three-up">
      <article class="card">
        <h3>Foundations</h3>
        <p class="muted">
          A strong grounding in rhythm, posture, coordination and core technique for younger children or complete beginners.
        </p>
      </article>

      <article class="card">
        <h3>Progression</h3>
        <p class="muted">
          Clear coaching for children already attending classes who would benefit from focused private attention and extra polish.
        </p>
      </article>

      <article class="card">
        <h3>Performance</h3>
        <p class="muted">
          Thoughtful preparation for shows, auditions, competitions or school performances, always tailored to the child’s goals.
        </p>
      </article>
    </div>

    <div class="two-up">
      <article class="section-panel">
        <h2>What parents can expect</h2>
        <p class="muted">
          Lessons balance encouragement and discipline, helping children develop artistry and confidence while enjoying the process.
        </p>
        <ul class="list">
          <li>Age-appropriate coaching and positive structure</li>
          <li>Support for recreational and ambitious young dancers</li>
          <li>Focus on confidence, consistency and enjoyment</li>
          <li>Suitable for private tuition or sibling sessions</li>
        </ul>
      </article>

      <article class="section-panel">
        <h2>Flexible lesson options</h2>
        <p class="muted">
          Sessions can be arranged around school schedules and family commitments, with formats designed to keep children engaged and progressing well.
        </p>
        <div class="details-grid">
          <div class="detail"><span>Age range</span><strong>Children and teens</strong></div>
          <div class="detail"><span>Formats</span><strong>Private or small shared sessions</strong></div>
          <div class="detail"><span>Length</span><strong>45 or 60 minutes</strong></div>
          <div class="detail"><span>Suitable for</span><strong>Beginners to aspiring performers</strong></div>
        </div>
      </article>
    </div>

    <div class="card">
      <p class="quote">
        Lessons are designed to feel inspiring, safe and beautifully well-guided from the very beginning.
      </p>
      <div class="hero-actions">
        <a class="button primary" href={withBase("/book/?lesson=children")}>Enquire about availability</a>
        <a class="button secondary" href={withBase("/")}>Return to adult lessons</a>
      </div>
    </div>
  </section>
</BaseLayout>
